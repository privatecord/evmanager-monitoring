{
  "uid": "evmanager-overview",
  "title": "EVManager Overview",
  "tags": ["evmanager", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "Prometheus"},
        "query": "label_values(container_last_seen{name=~\"evmanager.*\"}, name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {"id": 1, "type": "row", "title": "Overview", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}},
    {"id": 2, "type": "stat", "title": "Requests / sec", "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum(rate(http_requests_total[1m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}},
    {"id": 3, "type": "stat", "title": "Active users / sessions", "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum(active_sessions)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}},
    {"id": 4, "type": "stat", "title": "EVManager containers seen", "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "count(container_last_seen{name=~\"evmanager.*\"})", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}},
    {"id": 5, "type": "stat", "title": "HTTP 5xx error rate", "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}},

    {"id": 6, "type": "row", "title": "System Load", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}},
    {"id": 7, "type": "timeseries", "title": "Container CPU usage", "gridPos": {"x": 0, "y": 6, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"$container\"}[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}},
    {"id": 8, "type": "timeseries", "title": "Container RAM usage", "gridPos": {"x": 12, "y": 6, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "container_memory_working_set_bytes{name=~\"$container\"}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}},
    {"id": 9, "type": "timeseries", "title": "Host CPU load", "gridPos": {"x": 0, "y": 13, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}},
    {"id": 10, "type": "timeseries", "title": "Host memory usage", "gridPos": {"x": 12, "y": 13, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}},

    {"id": 11, "type": "row", "title": "Traffic", "gridPos": {"x": 0, "y": 20, "w": 24, "h": 1}},
    {"id": 12, "type": "timeseries", "title": "Requests by status code", "gridPos": {"x": 0, "y": 21, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum by (status) (rate(http_requests_total[1m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}},
    {"id": 13, "type": "timeseries", "title": "Request latency p95", "gridPos": {"x": 12, "y": 21, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}},
    {"id": 14, "type": "timeseries", "title": "Requests by route", "gridPos": {"x": 0, "y": 28, "w": 24, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum by (route) (rate(http_requests_total[1m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}},

    {"id": 15, "type": "row", "title": "Database", "gridPos": {"x": 0, "y": 35, "w": 24, "h": 1}},
    {"id": 16, "type": "timeseries", "title": "DB query rate", "gridPos": {"x": 0, "y": 36, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "sum by (operation, table) (rate(db_queries_total[1m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}},
    {"id": 17, "type": "timeseries", "title": "DB query latency p95", "gridPos": {"x": 12, "y": 36, "w": 12, "h": 7}, "datasource": {"type": "prometheus", "uid": "Prometheus"}, "targets": [{"expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le, operation))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}},

    {"id": 18, "type": "row", "title": "Logs", "gridPos": {"x": 0, "y": 43, "w": 24, "h": 1}},
    {"id": 19, "type": "logs", "title": "Recent EVManager logs", "gridPos": {"x": 0, "y": 44, "w": 24, "h": 8}, "datasource": {"type": "loki", "uid": "Loki"}, "targets": [{"expr": "{container=~\"evmanager.*\"}", "refId": "A"}], "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true}}
  ]
}
